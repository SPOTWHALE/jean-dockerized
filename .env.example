# Copy to .env and edit. docker-compose reads it automatically.
# All values are optional; leaving them unset uses the defaults below.

# Fixed access token for Jean's web UI. If unset, Jean auto-generates one and
# persists it in the workspace volume (printed in the startup logs). Set a long
# random string here to keep a stable token across volume wipes.
# JEAN_TOKEN=change-me-to-a-long-random-string

# Public URL of this instance (no trailing path). When set, the startup banner
# prints a ready login link and a scannable QR, so onboarding is one tap on a
# phone instead of copy-pasting a long token.
# JEAN_PUBLIC_URL=https://jean.example.com

# Jean web UI port (inside the container; compose maps it to 127.0.0.1).
# JEAN_PORT=3456

# Preview reverse-proxy port (<port>.<your-wildcard-domain> -> dev servers).
# PREVIEW_PORT=8088

# Preview subdomains are DISABLED (403) until PREVIEW_PASSWORD is set. Setting it
# gates every preview port behind one HTTP basic-auth login; PREVIEW_USER defaults
# to "dev". Fails closed so a misconfigured deploy never exposes loopback ports.
# PREVIEW_USER=dev
# PREVIEW_PASSWORD=change-me
