# Copy to .env and edit. docker-compose reads it automatically.
# All values are optional; leaving them unset uses the defaults below.

# Fixed access token for Jean's web UI. If unset, Jean auto-generates one and
# persists it in the workspace volume (printed in the startup logs). Set a long
# random string here to keep a stable token across volume wipes.
# JEAN_TOKEN=change-me-to-a-long-random-string

# Public URL of this instance (no trailing path). When set, the startup banner
# prints a ready login link and a scannable QR, so onboarding is one tap on a
# phone instead of copy-pasting a long token.
# JEAN_PUBLIC_URL=https://jean.example.com

# Jean web UI port (inside the container; compose maps it to 127.0.0.1).
# JEAN_PORT=3456

# Preview reverse-proxy port (<port>.<your-wildcard-domain> -> dev servers).
# PREVIEW_PORT=8088

# Preview subdomains are DISABLED (403) until PREVIEW_PASSWORD is set. Setting it
# gates every preview port behind one HTTP basic-auth login; PREVIEW_USER defaults
# to "dev". Fails closed so a misconfigured deploy never exposes loopback ports.
# The bundled Theia IDE is behind this same gate, so PREVIEW_PASSWORD also unlocks
# the IDE.
# PREVIEW_USER=dev
# PREVIEW_PASSWORD=change-me

# Bundled Theia IDE (per-worktree). A dispatcher runs one Theia per git worktree and
# routes by hostname through the preview proxy: ide.<wildcard> is a picker, and
# <repo>-<branch>.<wildcard> opens that worktree's scoped editor. NOTE: this is
# COSMETIC scoping (sidebar rooted at one worktree) - NOT a security boundary; the
# Theia terminal still reaches all of /workspace.
#
# The IDE button targets the preview wildcard - subdomains of your JEAN_PUBLIC_URL
# host (single-wildcard deploy: app jean.example.com, previews/IDE *.jean.example.com).
# It's derived from JEAN_PUBLIC_URL automatically; no separate env. Without
# JEAN_PUBLIC_URL the button falls back to ".<current-host>".
#
# Internal loopback port the dispatcher listens on (Caddy forwards non-numeric
# preview labels here). Rarely needs changing.
# THEIA_DISPATCH_PORT=8444

# Web Push notifications. A "🔔" button in Jean's toolbar subscribes your
# browser/phone so the agent can notify you when it finishes a turn, errors, or
# needs approval - even with the tab closed. Reached through the preview proxy at
# jdpush.<wildcard>, so it uses subdomains of your JEAN_PUBLIC_URL host - setting
# JEAN_PUBLIC_URL is what enables push. JEAN_TOKEN is optional; if unset, the relay
# uses jean's auto-generated token. Disabled when JEAN_PUBLIC_URL is unset.
#
# Subject the relay sends to push services as the VAPID contact (mailto: or URL).
# PUSH_SUBJECT=mailto:you@example.com
#
# Internal loopback port the relay listens on (Caddy forwards jdpush.<host> here).
# Rarely needs changing.
# PUSH_PORT=8455
#
# The "Claude backend" runs Claude Code as a terminal TUI, which emits no chat
# lifecycle events - so the relay instead pushes when the terminal goes silent
# for this many milliseconds (Claude finished its turn or is waiting on you).
# Set 0 to disable idle pushes (then only native chat-session events notify).
# Heuristic: Claude's spinner doesn't stream, so multi-second silent gaps are
# normal mid-turn; 20s default avoids most mid-work false fires. Lower = faster
# but noisier pings (a false fire is replaced by the real one via same tag).
# PUSH_IDLE_MS=20000
